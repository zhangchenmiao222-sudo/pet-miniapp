.page { background: #0F1923; min-height: 100vh; color: #fff; }
.nav-bar { display: flex; align-items: center; justify-content: space-between; padding: 100rpx 32rpx 24rpx; }
.nav-back { width: 60rpx; display: flex; align-items: center; }
.nav-back-icon { font-size: 48rpx; color: #fff; }
.nav-title { font-size: 32rpx; font-weight: bold; color: #fff; }
.nav-placeholder { width: 60rpx; }
.content { padding: 0 32rpx 80rpx; }
.formula-header-card { background: rgba(59,125,216,0.15); border-radius: 16rpx; padding: 40rpx; margin-bottom: 24rpx; }
.period-tag { display: inline-block; background: #3B7DD8; color: #fff; font-size: 22rpx; padding: 6rpx 20rpx; border-radius: 20rpx; margin-bottom: 16rpx; }
.formula-name { display: block; font-size: 40rpx; font-weight: bold; color: #fff; margin-bottom: 12rpx; }
.core-indicator { font-size: 26rpx; color: #8899AA; line-height: 1.6; }
.section-card { background: rgba(255,255,255,0.05); border-radius: 16rpx; padding: 32rpx; margin-bottom: 24rpx; }
.section-title { display: block; font-size: 28rpx; color: #8899AA; margin-bottom: 24rpx; }
.nutrients-row { display: flex; align-items: center; justify-content: space-around; }
.nutrient-item { display: flex; flex-direction: column; align-items: center; }
.nutrient-val { font-size: 40rpx; font-weight: bold; color: #3B7DD8; }
.nutrient-label { font-size: 22rpx; color: #8899AA; margin-top: 8rpx; }
.nutrient-sep { width: 1rpx; height: 60rpx; background: rgba(255,255,255,0.1); }
.tags-row { display: flex; flex-wrap: wrap; gap: 16rpx; }
.nutrient-tag { background: rgba(76,175,80,0.2); border-radius: 20rpx; padding: 8rpx 24rpx; }
.nutrient-tag-text { font-size: 26rpx; color: #4CAF50; }
.ingredient-item { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.06); }
.ingredient-item:last-child { border-bottom: none; }
.ingredient-name { font-size: 30rpx; color: #fff; display: block; }
.ingredient-category { font-size: 22rpx; color: #8899AA; margin-top: 4rpx; display: block; }
.ingredient-amount { font-size: 30rpx; color: #3B7DD8; font-weight: bold; }
.loading-wrap { padding: 100rpx; text-align: center; }
.loading-text { color: #8899AA; font-size: 28rpx; }
