.page { background: #0F1923; min-height: 100vh; color: #fff; }
.nav-bar { display: flex; align-items: center; justify-content: space-between; padding: 100rpx 32rpx 24rpx; }
.nav-back { width: 60rpx; display: flex; align-items: center; }
.nav-back-icon { font-size: 48rpx; color: #fff; }
.nav-title { font-size: 32rpx; font-weight: bold; color: #fff; }
.nav-placeholder { width: 60rpx; }
.content { padding: 0 32rpx 80rpx; }

/* 报告头部 */
.report-header-card { background: rgba(59,125,216,0.15); border-radius: 16rpx; padding: 40rpx; margin-bottom: 24rpx; }
.report-top-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20rpx; }
.report-no { font-size: 24rpx; color: #8899AA; }
.verified-badge { background: #4CAF50; color: #fff; font-size: 20rpx; padding: 4rpx 16rpx; border-radius: 6rpx; font-weight: bold; }
.report-main-title { display: block; font-size: 40rpx; font-weight: bold; color: #fff; margin-bottom: 12rpx; }
.report-sub { font-size: 24rpx; color: #8899AA; line-height: 1.6; }

/* 通用卡片 */
.section-card { background: rgba(255,255,255,0.05); border-radius: 16rpx; padding: 32rpx; margin-bottom: 24rpx; }
.section-title { display: block; font-size: 28rpx; color: #8899AA; margin-bottom: 24rpx; font-weight: bold; }

/* 雷达图 */
.radar-wrap { display: flex; justify-content: center; padding: 20rpx 0; }
.radar-canvas { width: 500rpx; height: 500rpx; }

/* 三级指标汇总 */
.score-summary { display: flex; justify-content: space-between; gap: 16rpx; }
.score-block { flex: 1; display: flex; flex-direction: column; align-items: center; padding: 24rpx 0; border-radius: 12rpx; }
.green-block { background: rgba(76,175,80,0.15); }
.orange-block { background: rgba(255,152,0,0.15); }
.blue-block { background: rgba(59,125,216,0.15); }
.score-block-num { font-size: 48rpx; font-weight: bold; }
.green-block .score-block-num { color: #4CAF50; }
.orange-block .score-block-num { color: #FF9800; }
.blue-block .score-block-num { color: #3B7DD8; }
.score-block-label { font-size: 22rpx; color: #8899AA; margin-top: 8rpx; }

/* 六维详细评分 */
.dimension-list { display: flex; flex-direction: column; gap: 20rpx; }
.dimension-item { display: flex; align-items: center; justify-content: space-between; }
.dim-left { min-width: 140rpx; }
.dim-name { font-size: 26rpx; color: #fff; }
.dim-right { flex: 1; display: flex; align-items: center; gap: 16rpx; margin-left: 20rpx; }
.dim-bar-bg { flex: 1; height: 12rpx; background: rgba(255,255,255,0.1); border-radius: 6rpx; overflow: hidden; }
.dim-bar-fill { height: 100%; border-radius: 6rpx; transition: width 0.3s; }
.dim-bar-fill.green { background: #4CAF50; }
.dim-bar-fill.orange { background: #FF9800; }
.dim-bar-fill.red { background: #EF4444; }
.dim-score { font-size: 28rpx; color: #fff; font-weight: bold; min-width: 60rpx; text-align: right; }
.dim-score.red { color: #EF4444; }

/* 14项核心指标 */
.indicator-list { display: flex; flex-direction: column; }
.indicator-item { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.06); }
.indicator-item:last-child { border-bottom: none; }
.ind-left { flex: 1; }
.ind-name { font-size: 28rpx; color: #fff; display: block; }
.ind-desc { font-size: 22rpx; color: #8899AA; margin-top: 4rpx; display: block; }
.ind-right { display: flex; align-items: center; gap: 16rpx; }
.ind-value { font-size: 28rpx; color: #fff; font-weight: bold; }
.ind-status { font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 6rpx; }
.ind-status.green { background: rgba(76,175,80,0.2); color: #4CAF50; }
.ind-status.orange { background: rgba(255,152,0,0.2); color: #FF9800; }
.ind-status.red { background: rgba(239,68,68,0.2); color: #EF4444; }

/* 加载/空状态 */
.loading-wrap, .empty-wrap { padding: 200rpx 0; text-align: center; }
.loading-text, .empty-text { color: #8899AA; font-size: 28rpx; }
