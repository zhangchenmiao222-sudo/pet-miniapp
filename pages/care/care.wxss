.page-container {
  height: 100vh;
  background-color: var(--bg-primary);
  padding-bottom: 40rpx;
}

/* ===== 顶部品牌栏 ===== */
.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: rgba(0, 0, 0, 0.3);
}
.brand-name {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
}
.brand-sub {
  font-size: 20rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}
.member-tag {
  background: var(--accent-blue);
  color: #fff;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
}

/* ===== 通用 section ===== */
.section {
  margin: 0 24rpx 24rpx;
}
.card {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 28rpx;
  border: 1rpx solid var(--border-color);
}
.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}
.section-sub {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
}

/* ===== 宠物信息 ===== */
.pet-section { margin-top: 24rpx; }
.pet-name {
  font-size: 60rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}
.pet-basic {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}
.pet-tags { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 16rpx; }
.health-tag {
  background: rgba(59, 125, 216, 0.15);
  color: var(--accent-blue);
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  border: 1rpx solid rgba(59, 125, 216, 0.3);
}
.pet-no { font-size: 22rpx; color: var(--text-muted); margin-bottom: 12rpx; }
.smart-tag {
  display: inline-block;
  background: rgba(76, 175, 80, 0.15);
  color: var(--accent-green);
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  border: 1rpx solid rgba(76, 175, 80, 0.3);
}

/* ===== 配方卡片 ===== */
.card-label { font-size: 24rpx; color: var(--text-secondary); margin-bottom: 8rpx; }
.formula-name {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}
.formula-indicator { font-size: 24rpx; color: var(--text-secondary); margin-bottom: 20rpx; }
.ingredients-row { display: flex; gap: 16rpx; margin-bottom: 12rpx; }
.ingredient-item { font-size: 26rpx; color: var(--text-primary); }
.nutrients-tags { display: flex; gap: 12rpx; margin-bottom: 20rpx; }
.nutrient-tag {
  background: rgba(76, 175, 80, 0.15);
  color: var(--accent-green);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}
.nutrition-bar {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
  padding: 16rpx;
  background: rgba(255,255,255,0.03);
  border-radius: 8rpx;
}
.read-more { font-size: 26rpx; color: var(--accent-blue); text-align: right; margin-top: 8rpx; }

/* ===== 医学报告 ===== */
.report-header { display: flex; align-items: center; gap: 16rpx; margin-bottom: 12rpx; }
.report-no { font-size: 24rpx; color: var(--text-secondary); }
.verified-tag {
  background: rgba(59, 125, 216, 0.2);
  color: var(--accent-blue);
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  font-weight: bold;
}
.radar-placeholder {
  height: 320rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 20rpx 0;
}
.report-scores { margin: 16rpx 0; }
.score-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx dashed var(--border-color);
}
.score-icon { font-size: 24rpx; margin-right: 12rpx; }
.score-label { flex: 1; font-size: 26rpx; color: var(--text-secondary); }
.score-num { font-size: 28rpx; font-weight: bold; }
.green { color: var(--accent-green); }
.orange { color: var(--accent-orange); }
.blue { color: var(--accent-blue); }
.report-btn {
  text-align: center;
  margin-top: 24rpx;
  padding: 20rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 40rpx;
  font-size: 26rpx;
  color: var(--text-primary);
}

/* ===== 养护看板 ===== */
.dashboard-header { margin-bottom: 20rpx; }
.dashboard-sub { font-size: 24rpx; color: var(--text-secondary); margin-top: 4rpx; }
.total-food { margin-bottom: 24rpx; }
.total-num { font-size: 56rpx; font-weight: bold; color: var(--text-primary); }
.total-label { font-size: 24rpx; color: var(--text-secondary); margin-left: 8rpx; }
.food-circles { display: flex; justify-content: space-around; margin-bottom: 24rpx; }
.food-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 4rpx solid;
}
.blue-circle { border-color: var(--accent-blue); background: rgba(59,125,216,0.1); }
.orange-circle { border-color: var(--accent-orange); background: rgba(255,152,0,0.1); }
.green-circle { border-color: var(--accent-green); background: rgba(76,175,80,0.1); }
.circle-num { font-size: 26rpx; font-weight: bold; color: var(--text-primary); }
.circle-label { font-size: 20rpx; color: var(--text-secondary); margin-top: 4rpx; }

/* 散步 */
.walk-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(30, 60, 100, 0.4);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
}
.walk-title { font-size: 26rpx; font-weight: bold; color: var(--text-primary); }
.walk-desc { font-size: 22rpx; color: var(--text-secondary); margin-top: 4rpx; }
.walk-status {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 3rpx solid var(--accent-blue);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--accent-blue);
}
.walk-status.done { background: var(--accent-blue); color: #fff; }

/* 饮水 */
.water-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.water-num { font-size: 56rpx; font-weight: bold; color: var(--text-primary); }
.water-unit { font-size: 22rpx; color: var(--text-secondary); margin-left: 8rpx; }
.add-water-btn {
  background: var(--accent-blue);
  color: #fff;
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: bold;
}

/* 额外记录 */
.extra-section { border-top: 1rpx solid var(--border-color); padding-top: 20rpx; }
.extra-header { display: flex; justify-content: space-between; margin-bottom: 16rpx; }
.extra-title { font-size: 28rpx; color: var(--text-primary); }
.extra-item {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
  font-size: 26rpx;
  color: var(--text-secondary);
  border-bottom: 1rpx solid var(--border-color);
}
.extra-amount { color: var(--text-primary); }
.add-extra-btn {
  text-align: center;
  margin-top: 16rpx;
  padding: 16rpx;
  border: 1rpx dashed var(--accent-blue);
  border-radius: 8rpx;
  font-size: 26rpx;
  color: var(--accent-blue);
}

/* ===== 料程 ===== */
.stage-tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
}
.stage-tab {
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
  background: rgba(255,255,255,0.05);
  border: 1rpx solid var(--border-color);
}
.stage-tab.active {
  background: var(--accent-blue);
  color: #fff;
  border-color: var(--accent-blue);
}
.live-header { display: flex; align-items: center; gap: 16rpx; margin-bottom: 12rpx; }
.live-stage { font-size: 28rpx; font-weight: bold; color: var(--text-primary); }
.live-tag {
  background: var(--accent-green);
  color: #fff;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  font-weight: bold;
}
.progress-bar-wrap {
  height: 10rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 5rpx;
  margin-bottom: 12rpx;
  overflow: hidden;
}
.progress-bar {
  height: 100%;
  background: var(--accent-blue);
  border-radius: 5rpx;
  transition: width 0.3s;
}
.progress-text { font-size: 22rpx; color: var(--text-secondary); }

/* ===== 科普文章 ===== */
.article-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  line-height: 1.6;
}
.article-preview {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ===== 底部 ===== */
.page-bottom {
  text-align: center;
  font-size: 22rpx;
  color: var(--text-muted);
  padding: 30rpx 0 50rpx;
}
