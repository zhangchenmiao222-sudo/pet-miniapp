}

.breed-risk-bar-bg {
  width: 100%;
  height: 14rpx;
  background: #e2e8f0;
  border-radius: 14rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.breed-risk-bar-fill {
  height: 100%;
  background: linear-gradient(to right, #f87171, #dc2626);
  border-radius: 14rpx;
}

.breed-risk-item-desc {
  font-size: 20rpx;
  color: #64748b;
  font-weight: 600;
  line-height: 1.5;
  display: block;
}

.breed-risk-divider {
  height: 1rpx;
  background: #e2e8f0;
  margin: 24rpx 0;
}

.breed-risk-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.breed-risk-tag {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 20rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.breed-risk-tag.danger {
  background: #fef2f2;
  border: 1rpx solid #fecaca;
}

.breed-risk-tag.warning {
  background: #fffbeb;
  border: 1rpx solid #fde68a;
}

.breed-risk-tag.info {
  background: #eff6ff;
  border: 1rpx solid #bfdbfe;
}

.breed-risk-tag-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.danger-dot { background: #ef4444; }
.warning-dot { background: #f59e0b; }
.info-dot { background: #3b82f6; }

.breed-risk-tag-text {
  font-size: 22rpx;
  color: #374151;
  font-weight: 700;
}

.breed-risk-footer {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f1f5f9;
}

.breed-risk-footer-text {
  font-size: 18rpx;
  color: #94a3b8;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

/* =====================================================
   新增：社会证明
   ===================================================== */
.social-proof-card {
  background: #fff;
  border-radius: 48rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.06);
  border: 1rpx solid #f1f5f9;
}

.social-proof-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #1e293b;
  text-align: center;
  display: block;
  margin-bottom: 36rpx;
  letter-spacing: 1rpx;
}

.social-proof-grid {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-bottom: 40rpx;
}

.social-proof-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.social-proof-num {
  font-size: 40rpx;
  font-weight: 900;
  color: #1A3A5F;
  font-family: monospace;
}

.social-proof-label {
  font-size: 20rpx;
  color: #94a3b8;
  font-weight: 700;
}

.social-proof-sep {
  width: 1rpx;
  height: 60rpx;
  background: #e2e8f0;
}

.social-proof-reviews {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.social-proof-review {
  background: #f8fafc;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  border: 1rpx solid #f1f5f9;
}

.review-quote {
  font-size: 22rpx;
  color: #374151;
  font-weight: 600;
  line-height: 1.6;
  font-style: italic;
  display: block;
}

.review-author {
  font-size: 18rpx;
  color: #94a3b8;
  font-weight: 700;
  margin-top: 8rpx;
  display: block;
}

/* =====================================================
   底部导航栏
   ===================================================== */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 50;
  display: flex;
  justify-content: center;
  padding: 0 32rpx 32rpx;
}

.tab-bar-inner {
  width: 100%;
  max-width: 716rpx;
  height: 144rpx;
  position: relative;
  display: flex;
  align-items: flex-end;
}

.tab-bar-bg {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 144rpx;
  background: #1A3A5F;
  border-radius: 56rpx;
  box-shadow: 0 30rpx 100rpx rgba(26,58,95,0.4);
  z-index: 0;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding-bottom: 24rpx;
  position: relative;
  z-index: 10;
}

.tab-icon {
  font-size: 48rpx;
  opacity: 0.3;
}

.tab-item.active .tab-icon {
  opacity: 1;
}

.tab-label {
  font-size: 20rpx;
  font-weight: 900;
  color: rgba(255,255,255,0.3);
  letter-spacing: -0.5rpx;
}

.tab-label.active-label {
  color: #22d3ee;
}

.tab-center {
  flex: 1;
  display: flex;
  justify-content: center;
  position: relative;
  z-index: 20;
}

.tab-center-outer {
  width: 128rpx;
  height: 128rpx;
  background: #fff;
  border-radius: 50%;
  padding: 12rpx;
  box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.15);
  position: absolute;
  bottom: 12rpx;
}

.tab-center-inner {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #06b6d4, #67e8f9);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.tab-center-icon {
  font-size: 60rpx;
}