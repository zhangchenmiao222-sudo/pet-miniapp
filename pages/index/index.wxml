<!-- 首页：对接真实 API，所有数据动态绑定 -->
<view class="container">

  <!-- ===================== 第一屏：英雄区 ===================== -->
  <view class="hero-section">
    <image class="hero-bg" src="https://images.unsplash.com/photo-1544568100-847a948585b9?q=80&w=1000&auto=format&fit=crop" mode="aspectFill" />
    <view class="hero-mask"></view>
    <view class="hero-radial"></view>

    <!-- 顶部品牌区 -->
    <view class="brand-area">
      <view class="brand-left">
        <view class="brand-icon"><text class="brand-icon-text">🔬</text></view>
        <view class="brand-info">
          <text class="brand-name">妙巧巧 · MPFD</text>
          <view class="brand-tags">
            <text class="brand-badge">国企品质 责任传承</text>
            <text class="brand-en">Animal Precision Nutrition</text>
          </view>
        </view>
      </view>
      <!-- 会员标识（成员C接口） -->
      <view class="member-tag" wx:if="{{memberInfo && memberInfo.is_active}}">
        <text class="member-tag-icon">👑</text>
        <text class="member-tag-text">{{pet.name || '会员'}} · {{memberInfo.member_type === 'month' ? '128¥' : memberInfo.member_type === 'quarter' ? '298¥' : '998¥'}}</text>
      </view>
      <view class="member-tag-empty" wx:elif="{{memberInfo && !memberInfo.is_active}}" bindtap="goMemberPage">
        <text class="member-tag-text">开通会员</text>
      </view>
    </view>

    <!-- 宠物标签 -->
    <view class="pet-tags" wx:if="{{pet}}">
      <view class="pet-tag-pill">{{pet.name}} · {{pet.age_years}}岁</view>
      <view class="pet-tag-id">NO. {{pet.pet_no}}</view>
    </view>

    <!-- 宠物名称与信息 -->
    <view class="pet-identity" wx:if="{{pet}}">
      <view class="share-btn" bindtap="onShareCard">
        <text class="share-btn-icon">↗</text>
        <text class="share-btn-text">分享档案</text>
      </view>
      <text class="pet-name">{{pet.name}}</text>
      <text class="pet-info">{{pet.breed}} · {{pet.age_years}}岁 · {{pet.weight_kg}}kg</text>
      <view class="pet-status">
        <view class="status-pill" wx:for="{{pet.health_tags}}" wx:key="index">
          <text class="status-text">{{item}}</text>
        </view>
      </view>
      <view class="checkup-tag" wx:if="{{pet.checkup_date}}">
        <text class="checkup-icon">🛡️</text>
        <text class="checkup-text">最近体检：{{pet.checkup_date}} · 14项指标检测完毕</text>
      </view>
    </view>

    <!-- 过渡文案 -->
    <view class="transition-guide" wx:if="{{pet}}">
      <view class="transition-line"></view>
      <text class="transition-text">基于以上检测结果，我们为{{pet.name}}定制了专属营养方案 ↓</text>
      <view class="transition-line"></view>
    </view>

    <!-- ========== 专属配方卡片 ========== -->
    <view class="formula-card" wx:if="{{formula}}">
      <view class="formula-reason">
        <text class="formula-reason-icon">🩸</text>
        <text class="formula-reason-text">{{formula.core_indicator}}</text>
      </view>
      <view class="formula-header">
        <view class="formula-label-row">
          <text class="formula-label">专属配方</text>
          <view class="formula-dot"></view>
          <text class="formula-label">第{{formula.period_num}}期</text>
        </view>
        <text class="formula-title">「{{formula.name}}」</text>
      </view>

      <view class="formula-content">
        <view class="formula-img-wrap">
          <image class="formula-img" src="https://images.unsplash.com/photo-1596492784531-6e6eb5ea9993?q=80&w=400&h=400&auto=format&fit=crop" mode="aspectFill" />
          <view class="formula-img-badge">
            <text class="formula-img-badge-icon">📷</text>
            <text class="formula-img-badge-text">实拍</text>
          </view>
        </view>

        <view class="formula-details">
          <!-- 食材列表 -->
          <view class="formula-detail-item" wx:if="{{ingredients.length > 0}}">
            <view class="detail-icon-wrap red"><text class="detail-emoji">🥩</text></view>
            <view class="detail-text">
              <text class="detail-label">蛋白组合</text>
              <text class="detail-value">{{ingredients[0].name}}{{ingredients.length > 1 ? '·' + ingredients[1].name : ''}}{{ingredients.length > 2 ? '·' + ingredients[2].name : ''}}</text>
            </view>
          </view>
          <!-- 特殊营养素 -->
          <view class="formula-detail-item" wx:if="{{formula.special_nutrients.length > 0}}">
            <view class="detail-icon-wrap yellow"><text class="detail-emoji">💊</text></view>
            <view class="detail-text">
              <text class="detail-label">特调补充</text>
              <text class="detail-value">{{formula.special_nutrients.join('·')}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="formula-footer">
        <view class="formula-nutrients">
          <text class="nutrient-text">蛋白质 {{formula.protein_pct}}%</text>
          <view class="nutrient-sep"></view>
          <text class="nutrient-text">脂肪 {{formula.fat_pct}}%</text>
          <view class="nutrient-sep"></view>
          <text class="nutrient-text">{{formula.calories_per_100g}}千卡/100g</text>
        </view>
        <text class="formula-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- ===================== 第二屏：功能区 ===================== -->
  <view class="function-area">

    <!-- ========== 医学综合分析报告（成员C接口） ========== -->
    <view class="report-card" wx:if="{{report}}">
      <view class="emotion-banner">
        <text class="emotion-text">每一项指标背后，都是我们对{{pet.name}}健康的深度守护</text>
      </view>
      <view class="report-header">
        <view class="report-header-bg">🔬</view>
        <view class="report-header-content">
          <view class="report-header-left">
            <view class="report-badges">
              <text class="report-badge-id">{{report.report_no}}</text>
              <text class="report-badge-verified" wx:if="{{report.verified}}">Verified</text>
            </view>
            <text class="report-title">医学综合分析报告</text>
            <text class="report-subtitle">{{report.total_pages}}页深度解析 · 涵盖6大生理系统</text>
          </view>
          <view class="report-icon-box"><text class="report-icon-text">📄</text></view>
        </view>
      </view>

      <view class="report-body">
        <view class="report-inner-card">
          <view class="radar-title-row">
            <text class="radar-title">全系统多维健康透析画像</text>
            <text class="radar-badge">14项核心指标</text>
          </view>
          <view class="radar-chart-wrap">
            <text class="radar-label top {{alertFlags[0] ? 'red' : ''}}">消化系统</text>
            <text class="radar-label top-right {{alertFlags[1] ? 'red' : ''}}">骨骼肌肉</text>
            <text class="radar-label bottom-right {{alertFlags[2] ? 'red' : ''}}">皮肤毛发</text>
            <text class="radar-label bottom {{alertFlags[3] ? 'red' : ''}}">心血管</text>
            <text class="radar-label bottom-left {{alertFlags[4] ? 'red' : ''}}">免疫系统</text>
            <text class="radar-label top-left {{alertFlags[5] ? 'red' : ''}}">内分泌</text>
            <canvas type="2d" id="radarCanvas" class="radar-canvas"></canvas>
          </view>

          <view class="conclusion-list">
            <view class="conclusion-item">
              <view class="conclusion-icon green">✓</view>
              <view class="conclusion-text">
                <text class="conclusion-title">卓越健康指标</text>
                <text class="conclusion-desc">心血管及免疫系统表现优异</text>
              </view>
              <view class="conclusion-count">
                <text class="count-num green">{{report.excellent_count}}</text>
                <text class="count-unit">项</text>
              </view>
            </view>
            <view class="conclusion-item">
              <view class="conclusion-icon amber">⚠</view>
              <view class="conclusion-text">
                <text class="conclusion-title">黄金观察期</text>
                <text class="conclusion-desc">代谢指标微小波动，已纳入监控</text>
              </view>
              <view class="conclusion-count">
                <text class="count-num amber">{{report.observe_count}}</text>
                <text class="count-unit">项</text>
              </view>
            </view>
            <view class="conclusion-item">
              <view class="conclusion-icon blue">⚗</view>
              <view class="conclusion-text">
                <text class="conclusion-title">专属营养干预中</text>
                <text class="conclusion-desc-blue">针对性方案已生效执行</text>
              </view>
              <view class="conclusion-count">
                <text class="count-num blue">{{report.intervene_count}}</text>
                <text class="count-unit">项</text>
              </view>
            </view>
          </view>
        </view>

        <view class="report-btn" bindtap="goReportDetail">
          <text class="report-btn-icon">📄</text>
          <text class="report-btn-text">查阅 {{report.total_pages}} 页完整分析报告</text>
          <text class="report-btn-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- ========== 今日养护看板（成员A接口） ========== -->
    <view class="care-card" wx:if="{{dailyCare}}">
      <view class="care-bg-circle"></view>
      <view class="care-content">
        <view class="care-header">
          <view class="care-header-left">
            <view class="care-icon-box"><text class="care-icon-text">⚖️</text></view>
            <view class="care-title-wrap">
              <text class="care-title">今日养护看板</text>
              <text class="care-subtitle">第 {{dailyCare.meals_count}} 餐 · 第 {{dailyCare.day_count}} 天</text>
            </view>
          </view>
          <view class="care-status-tag">精准执行中</view>
        </view>

        <view class="meal-section">
          <view class="meal-total-row">
            <view class="meal-total-left">
              <view class="meal-dot"></view>
              <text class="meal-total-label">今日总食量：</text>
              <text class="meal-total-num">{{dailyCare.total_food_g}}</text>
              <text class="meal-total-unit">g</text>
            </view>
            <text class="meal-count-tag">分 {{dailyCare.meals_count}} 餐</text>
          </view>

          <view class="meal-grid">
            <view class="meal-item done">
              <view class="meal-check green">✓</view>
              <text class="meal-label">荤 食</text>
              <view class="meal-value-row">
                <text class="meal-num">{{dailyCare.meat_g}}</text>
                <text class="meal-unit">g</text>
              </view>
            </view>
            <view class="meal-item">
              <view class="meal-check pending"><view class="meal-pending-dot"></view></view>
              <text class="meal-label">中 食</text>
              <view class="meal-value-row">
                <text class="meal-num">{{dailyCare.middle_g}}</text>
                <text class="meal-unit">g</text>
              </view>
            </view>
            <view class="meal-item">
              <view class="meal-check pending"><view class="meal-pending-dot"></view></view>
              <text class="meal-label">蔬 食</text>
              <view class="meal-value-row">
                <text class="meal-num">{{dailyCare.veggie_g}}</text>
                <text class="meal-unit">g</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 散步指令 -->
        <view class="exercise-bar">
          <view class="exercise-left">
            <view class="exercise-icon">🐾</view>
            <view class="exercise-text">
              <text class="exercise-title">餐后散步指令</text>
              <text class="exercise-desc">{{dailyCare.walk_plan_name || '15-20 分钟 · 保持轻度活动'}}</text>
            </view>
          </view>
          <text class="exercise-tag">{{dailyCare.walk_completed ? '已完成 ✓' : '消化养护'}}</text>
        </view>

        <!-- 饮水 -->
        <view class="water-panel">
          <view class="water-glow"></view>
          <view class="water-top">
            <view class="water-info">
              <view class="water-icon-wrap"><text class="water-icon">💧</text></view>
              <view class="water-nums">
                <text class="water-target">今日目标 {{waterTarget}}ml</text>
                <view class="water-current-row">
                  <text class="water-current">{{waterIntake}}</text>
                  <text class="water-ml">ml</text>
                </view>
              </view>
            </view>
            <view class="water-btn {{waterIntake >= waterTarget ? 'disabled' : ''}}" bindtap="addWater">
              <text class="water-btn-text">+ 100ml</text>
            </view>
          </view>
          <view class="water-progress-bg">
            <view class="water-progress-fill" style="width: {{waterPercent}}%">
              <view class="water-shimmer"></view>
            </view>
          </view>
        </view>

        <!-- 额外记录 -->
        <view class="extra-section">
          <view class="extra-header">
            <text class="extra-title">📝 今日额外记录</text>
            <text class="extra-link">查看全部 ›</text>
          </view>
          <view class="extra-tags">
            <view class="extra-tag" wx:for="{{dailyCare.extra_records}}" wx:key="index">
              <text class="extra-tag-icon">🦴</text>
              <text class="extra-tag-text">{{item.name}} </text>
              <text class="extra-tag-value">{{item.amount}}</text>
            </view>
          </view>
          <view class="add-record-btn">
            <text class="add-record-text">+ [ 添加记录 ]</text>
          </view>
        </view>
      </view>
    </view>

    <!-- ========== 定制料程 ========== -->
    <view class="journey-card" bindtap="goJourneyDetail" wx:if="{{mealPlan}}">
      <view class="journey-header">
        <text class="journey-title">{{pet.name}}的专属定制旅程</text>
        <view class="journey-live-tag">
          <view class="journey-live-dot {{pulse ? 'on' : ''}}"></view>
          <text class="journey-live-text">{{mealPlan.is_live ? '定制进行中' : '已完成'}}</text>
        </view>
      </view>

      <view class="journey-progress">
        <view class="journey-track"><view class="journey-track-fill"></view></view>
        <view class="journey-nodes">
          <view class="journey-node-item">
            <view class="journey-node done">🔬</view>
            <text class="journey-node-label done-label">检测出具</text>
          </view>
          <view class="journey-node-item">
            <view class="journey-node done">🤖</view>
            <text class="journey-node-label done-label">配方生成</text>
          </view>
          <view class="journey-node-item">
            <view class="journey-node {{mealPlan.current_stage === 'additives' ? 'active' : 'done'}}">🔥</view>
            <view class="journey-node-ping" wx:if="{{mealPlan.current_stage === 'additives'}}"></view>
            <text class="journey-node-label {{mealPlan.current_stage === 'additives' ? 'active-label' : 'done-label'}}">备料生产</text>
          </view>
          <view class="journey-node-item">
            <view class="journey-node {{mealPlan.current_stage === 'feeding' ? 'active' : 'pending-node'}}">🚚</view>
            <text class="journey-node-label {{mealPlan.current_stage === 'feeding' ? 'active-label' : 'pending-label'}}">新鲜送达</text>
          </view>
        </view>
      </view>

      <view class="live-panel" wx:if="{{mealPlan.is_live}}">
        <view class="live-glow"></view>
        <view class="live-top">
          <view class="live-top-left">
            <view class="live-flask-icon">⚗️</view>
            <view class="live-top-text">
              <text class="live-process-label">Live Process</text>
              <text class="live-process-title">{{mealPlan.current_stage_label}}</text>
            </view>
          </view>
          <view class="live-badge">
            <view class="live-red-dot"></view>
            <text class="live-badge-text">LIVE</text>
          </view>
        </view>
        <view class="live-bottom">
          <view class="live-bottom-left">
            <view class="live-emoji-stack">
              <text class="live-emoji-item">🥩</text>
              <text class="live-emoji-item overlap">💊</text>
            </view>
            <text class="live-progress-label">备料进度</text>
          </view>
          <view class="live-progress-wrap">
            <view class="live-progress-bg">
              <view class="live-progress-fill" style="width: {{mealPlan.progress_pct}}%"></view>
            </view>
            <text class="live-progress-num">{{mealPlan.progress_pct}}%</text>
          </view>
        </view>
      </view>

      <view class="journey-footer">
        <text class="journey-footer-text">已计划 <text class="journey-footer-bold">{{mealPlan.planned_days}}</text> 天专属营养方案</text>
        <view class="journey-footer-link">
          <text class="journey-footer-link-text">查看详细日志 ›</text>
        </view>
      </view>
    </view>

    <!-- ========== 科普文章 ========== -->
    <view class="article-card" wx:for="{{articles}}" wx:key="id" bindtap="goArticleDetail" data-id="{{item.id}}">
      <view class="article-bg-shape"></view>
      <view class="article-content">
        <view class="article-head">
          <view class="article-icon-box"><text class="article-icon">📖</text></view>
          <text class="article-badge-text">📖 {{item.category || '报告深度解读'}}</text>
        </view>
        <text class="article-title">{{item.title}}</text>
        <view class="article-footer">
          <text class="article-author">妙巧巧·医学分析团队</text>
          <text class="article-read-more">阅读全文 ›</text>
        </view>
      </view>
    </view>

    <!-- 底部说明 -->
    <view class="footer-note">
      <text class="footer-note-text">每只犬的配方均不相同 · 配方基于血液检测报告自动生成</text>
      <text class="footer-note-sub">动物精准营养及预防医学中心提供技术支持</text>
    </view>
  </view>

</view>
