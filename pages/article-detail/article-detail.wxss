.page { background: #0F1923; min-height: 100vh; color: #fff; }
.nav-bar { display: flex; align-items: center; justify-content: space-between; padding: 100rpx 32rpx 24rpx; }
.nav-back { width: 60rpx; height: 60rpx; display: flex; align-items: center; }
.nav-back-icon { font-size: 48rpx; color: #fff; }
.nav-title { font-size: 32rpx; font-weight: bold; color: #fff; }
.nav-placeholder { width: 60rpx; }
.content { padding: 0 40rpx 80rpx; }
.category-tag { display: inline-block; background: rgba(59,125,216,0.2); color: #3B7DD8; font-size: 22rpx; padding: 6rpx 20rpx; border-radius: 20rpx; margin-bottom: 24rpx; }
.title { display: block; font-size: 40rpx; font-weight: bold; color: #fff; line-height: 1.5; margin-bottom: 24rpx; }
.meta-row { display: flex; justify-content: space-between; margin-bottom: 32rpx; }
.author { font-size: 24rpx; color: #8899AA; }
.views { font-size: 24rpx; color: #8899AA; }
.divider { height: 1rpx; background: rgba(255,255,255,0.1); margin-bottom: 40rpx; }
.body-text { font-size: 30rpx; color: #CDD6E0; line-height: 1.8; }
.loading-wrap { padding: 100rpx; text-align: center; }
.loading-text { color: #8899AA; font-size: 28rpx; }
