/* 我的邀请页面 */
.container { background: #0F1B2D; min-height: 100vh; }

/* 导航栏 */
.nav-bar { display: flex; align-items: center; padding: 88rpx 24rpx 24rpx; }
.nav-back { width: 60rpx; height: 60rpx; display: flex; align-items: center; justify-content: center; }
.nav-back-icon { color: #FFFFFF; font-size: 48rpx; font-weight: 300; }
.nav-title { color: #FFFFFF; font-size: 34rpx; font-weight: 700; margin-left: 8rpx; }

/* 汇总卡片 */
.summary-card { display: flex; align-items: center; justify-content: space-around; margin: 24rpx; background: linear-gradient(135deg, rgba(34,211,238,0.1), rgba(59,102,245,0.1)); border: 1rpx solid rgba(34,211,238,0.2); border-radius: 24rpx; padding: 36rpx 24rpx; }
.summary-item { display: flex; flex-direction: column; align-items: center; }
.summary-num { color: #22d3ee; font-size: 44rpx; font-weight: 700; font-family: monospace; }
.summary-label { color: rgba(255,255,255,0.5); font-size: 22rpx; margin-top: 8rpx; }
.summary-sep { width: 1rpx; height: 60rpx; background: rgba(255,255,255,0.1); }

/* Tab */
.tab-bar-custom { display: flex; margin: 24rpx; gap: 0; background: rgba(255,255,255,0.06); border-radius: 16rpx; overflow: hidden; }
.tab-item-custom { flex: 1; text-align: center; padding: 20rpx 0; }
.tab-item-custom.active { background: rgba(34,211,238,0.15); }
.tab-text { font-size: 28rpx; font-weight: 600; color: rgba(255,255,255,0.5); }
.tab-item-custom.active .tab-text { color: #22d3ee; }

/* 列表 */
.list { padding: 0 24rpx; }

/* 空状态 */
.empty-tip { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; }
.empty-icon { font-size: 72rpx; margin-bottom: 20rpx; }
.empty-text { color: rgba(255,255,255,0.7); font-size: 30rpx; font-weight: 600; }
.empty-desc { color: rgba(255,255,255,0.4); font-size: 24rpx; margin-top: 8rpx; }

/* 邀请记录卡 */
.invite-item { background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 20rpx; padding: 24rpx; margin-bottom: 16rpx; }
.invite-item-top { display: flex; justify-content: space-between; align-items: center; }
.invite-item-left { display: flex; align-items: center; gap: 16rpx; }
.invite-item-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; }
.invite-item-avatar-placeholder { width: 72rpx; height: 72rpx; border-radius: 50%; background: rgba(255,255,255,0.1); display: flex; align-items: center; justify-content: center; }
.invite-item-avatar-text { color: rgba(255,255,255,0.3); font-size: 32rpx; }
.invite-item-info { display: flex; flex-direction: column; }
.invite-item-name { color: #FFFFFF; font-size: 28rpx; font-weight: 600; }
.invite-item-pet { color: rgba(255,255,255,0.5); font-size: 22rpx; margin-top: 4rpx; }
.invite-item-status { padding: 6rpx 16rpx; border-radius: 20rpx; }
.status-pending { background: rgba(255,255,255,0.1); }
.status-accepted { background: rgba(34,211,238,0.15); }
.status-checkup_applied { background: rgba(245,158,11,0.15); }
.status-checkup_done { background: rgba(34,197,94,0.15); }
.status-converted { background: rgba(59,102,245,0.15); }
.invite-item-status-text { font-size: 22rpx; color: rgba(255,255,255,0.7); font-weight: 600; }
.invite-item-bottom { display: flex; justify-content: space-between; margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid rgba(255,255,255,0.06); }
.invite-item-code { color: rgba(255,255,255,0.4); font-size: 22rpx; font-family: monospace; }
.invite-item-time { color: rgba(255,255,255,0.3); font-size: 22rpx; }

/* 奖励卡 */
.reward-item { display: flex; justify-content: space-between; align-items: center; background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 20rpx; padding: 28rpx 24rpx; margin-bottom: 16rpx; }
.reward-item-left { display: flex; flex-direction: column; }
.reward-amount { display: flex; align-items: baseline; gap: 4rpx; }
.reward-amount-num { color: #22d3ee; font-size: 48rpx; font-weight: 700; }
.reward-amount-unit { color: #22d3ee; font-size: 24rpx; }
.reward-desc { color: rgba(255,255,255,0.6); font-size: 24rpx; margin-top: 4rpx; }
.reward-from { color: rgba(255,255,255,0.4); font-size: 22rpx; margin-top: 4rpx; }
.reward-item-right { display: flex; flex-direction: column; align-items: flex-end; }
.reward-status { padding: 6rpx 16rpx; border-radius: 20rpx; }
.reward-status-pending { background: rgba(255,255,255,0.1); }
.reward-status-active { background: rgba(34,197,94,0.15); }
.reward-status-used { background: rgba(255,255,255,0.06); }
.reward-status-expired { background: rgba(239,68,68,0.1); }
.reward-status-text { font-size: 22rpx; color: rgba(255,255,255,0.7); font-weight: 600; }
.reward-expire { color: rgba(255,255,255,0.3); font-size: 20rpx; margin-top: 8rpx; }
