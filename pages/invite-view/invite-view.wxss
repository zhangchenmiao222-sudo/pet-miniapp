/* 子号浏览母号页面样式 */
.container { background: #0F1B2D; min-height: 100vh; padding-bottom: env(safe-area-inset-bottom); }

/* 加载 */
.loading-wrap { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; }
.loading-spinner { width: 60rpx; height: 60rpx; border: 4rpx solid rgba(34,211,238,0.3); border-top-color: #22d3ee; border-radius: 50%; animation: spin 0.8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { color: rgba(255,255,255,0.6); font-size: 28rpx; margin-top: 20rpx; }

/* 邀请横幅 */
.invite-banner { display: flex; align-items: center; padding: 32rpx; background: linear-gradient(135deg, rgba(34,211,238,0.15), rgba(59,102,245,0.15)); margin: 24rpx; border-radius: 20rpx; border: 1rpx solid rgba(34,211,238,0.2); }
.invite-avatar-img { width: 80rpx; height: 80rpx; border-radius: 50%; margin-right: 24rpx; }
.invite-banner-title { color: #22d3ee; font-size: 30rpx; font-weight: 600; }
.invite-banner-desc { color: rgba(255,255,255,0.7); font-size: 24rpx; margin-top: 6rpx; display: block; }

/* 英雄区 */
.hero-section { position: relative; padding: 0 24rpx 40rpx; }
.hero-bg { position: absolute; top: 0; left: 0; width: 100%; height: 600rpx; z-index: 0; }
.hero-mask { position: absolute; top: 0; left: 0; width: 100%; height: 600rpx; background: linear-gradient(180deg, rgba(15,27,45,0.7) 0%, #0F1B2D 100%); z-index: 1; }

.brand-area { position: relative; z-index: 2; display: flex; align-items: center; padding: 40rpx 0 20rpx; }
.brand-left { display: flex; align-items: center; }
.brand-icon { width: 64rpx; height: 64rpx; background: rgba(34,211,238,0.15); border-radius: 16rpx; display: flex; align-items: center; justify-content: center; margin-right: 16rpx; }
.brand-icon-text { font-size: 32rpx; }
.brand-info { display: flex; flex-direction: column; }
.brand-name { color: #FFFFFF; font-size: 32rpx; font-weight: 700; }
.brand-en { color: rgba(255,255,255,0.5); font-size: 20rpx; }

.pet-identity { position: relative; z-index: 2; padding: 20rpx 0; }
.pet-name { color: #FFFFFF; font-size: 48rpx; font-weight: 700; display: block; }
.pet-info { color: rgba(255,255,255,0.7); font-size: 26rpx; display: block; margin-top: 8rpx; }
.pet-status { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 16rpx; }
.status-pill { background: rgba(34,211,238,0.12); border: 1rpx solid rgba(34,211,238,0.25); border-radius: 24rpx; padding: 6rpx 18rpx; }
.status-text { color: #22d3ee; font-size: 22rpx; }

/* 配方卡片 */
.formula-card { position: relative; z-index: 2; background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.1); border-radius: 24rpx; padding: 28rpx; margin-top: 24rpx; }
.formula-reason { display: flex; align-items: center; margin-bottom: 16rpx; }
.formula-reason-icon { font-size: 28rpx; margin-right: 8rpx; }
.formula-reason-text { color: rgba(255,255,255,0.7); font-size: 24rpx; }
.formula-header { margin-bottom: 16rpx; }
.formula-label-row { display: flex; align-items: center; gap: 8rpx; margin-bottom: 8rpx; }
.formula-label { color: rgba(255,255,255,0.5); font-size: 22rpx; }
.formula-dot { width: 6rpx; height: 6rpx; background: #22d3ee; border-radius: 50%; }
.formula-title { color: #FFFFFF; font-size: 34rpx; font-weight: 600; }
.formula-footer { border-top: 1rpx solid rgba(255,255,255,0.08); padding-top: 16rpx; }
.formula-nutrients { display: flex; align-items: center; gap: 16rpx; }
.nutrient-text { color: rgba(255,255,255,0.6); font-size: 22rpx; }
.nutrient-sep { width: 1rpx; height: 20rpx; background: rgba(255,255,255,0.2); }

/* 报告卡片 */
.report-card { margin: 24rpx; background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 24rpx; overflow: hidden; }
.emotion-banner { background: linear-gradient(90deg, rgba(34,211,238,0.1), rgba(59,102,245,0.1)); padding: 20rpx 28rpx; }
.emotion-text { color: rgba(255,255,255,0.7); font-size: 24rpx; font-style: italic; }
.report-header { padding: 28rpx; }
.report-header-content { display: flex; justify-content: space-between; }
.report-header-left { flex: 1; }
.report-badges { display: flex; align-items: center; gap: 12rpx; margin-bottom: 12rpx; }
.report-badge-id { color: rgba(255,255,255,0.5); font-size: 22rpx; font-family: monospace; }
.report-badge-verified { background: rgba(34,211,238,0.2); color: #22d3ee; font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 8rpx; }
.report-title { color: #FFFFFF; font-size: 34rpx; font-weight: 700; display: block; }
.report-subtitle { color: rgba(255,255,255,0.5); font-size: 24rpx; display: block; margin-top: 8rpx; }

.report-body { padding: 0 28rpx 28rpx; }
.report-inner-card { background: rgba(255,255,255,0.04); border-radius: 20rpx; padding: 24rpx; }
.radar-title-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.radar-title { color: #FFFFFF; font-size: 28rpx; font-weight: 600; }
.radar-badge { background: rgba(59,102,245,0.2); color: #6B8AF5; font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 8rpx; }
.radar-chart-wrap { position: relative; width: 100%; height: 400rpx; margin: 20rpx 0; }
.radar-canvas { width: 100%; height: 100%; }
.radar-label { position: absolute; color: rgba(255,255,255,0.6); font-size: 22rpx; }
.radar-label.red { color: #EF4444; font-weight: 600; }
.radar-label.top { top: 0; left: 50%; transform: translateX(-50%); }
.radar-label.top-right { top: 20%; right: 0; }
.radar-label.bottom-right { bottom: 20%; right: 0; }
.radar-label.bottom { bottom: 0; left: 50%; transform: translateX(-50%); }
.radar-label.bottom-left { bottom: 20%; left: 0; }
.radar-label.top-left { top: 20%; left: 0; }

.conclusion-list { display: flex; flex-direction: column; gap: 16rpx; }
.conclusion-item { display: flex; align-items: center; }
.conclusion-icon { width: 40rpx; height: 40rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20rpx; margin-right: 16rpx; }
.conclusion-icon.green { background: rgba(34,197,94,0.15); color: #22C55E; }
.conclusion-icon.amber { background: rgba(245,158,11,0.15); color: #F59E0B; }
.conclusion-icon.blue { background: rgba(59,102,245,0.15); color: #3B66F5; }
.conclusion-text { flex: 1; }
.conclusion-title { color: rgba(255,255,255,0.8); font-size: 26rpx; }
.conclusion-count { display: flex; align-items: baseline; }
.count-num { font-size: 36rpx; font-weight: 700; }
.count-num.green { color: #22C55E; }
.count-num.amber { color: #F59E0B; }
.count-num.blue { color: #3B66F5; }
.count-unit { color: rgba(255,255,255,0.5); font-size: 22rpx; margin-left: 4rpx; }

/* 养护卡片 */
.care-card { margin: 24rpx; background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 24rpx; padding: 28rpx; }
.care-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.care-header-left { display: flex; align-items: center; gap: 12rpx; }
.care-icon-text { font-size: 32rpx; }
.care-title { color: #FFFFFF; font-size: 30rpx; font-weight: 600; }
.care-status-tag { background: rgba(34,211,238,0.15); color: #22d3ee; font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 20rpx; }
.meal-grid { display: flex; gap: 16rpx; }
.meal-item { flex: 1; background: rgba(255,255,255,0.04); border-radius: 16rpx; padding: 20rpx; text-align: center; }
.meal-label { color: rgba(255,255,255,0.5); font-size: 24rpx; display: block; }
.meal-num { color: #FFFFFF; font-size: 32rpx; font-weight: 600; display: block; margin-top: 8rpx; }

/* 定制旅程 */
.journey-card { margin: 24rpx; background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 24rpx; padding: 28rpx; }
.journey-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32rpx; }
.journey-title { color: #FFFFFF; font-size: 30rpx; font-weight: 600; }
.journey-live-tag { display: flex; align-items: center; gap: 8rpx; }
.journey-live-dot { width: 12rpx; height: 12rpx; background: #EF4444; border-radius: 50%; }
.journey-live-dot.on { animation: pulse 2s infinite; }
@keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
.journey-live-text { color: #EF4444; font-size: 22rpx; }
.journey-nodes { display: flex; justify-content: space-between; }
.journey-node-item { display: flex; flex-direction: column; align-items: center; flex: 1; }
.journey-node { width: 72rpx; height: 72rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 32rpx; }
.journey-node.done { background: rgba(34,197,94,0.15); }
.journey-node.active { background: rgba(34,211,238,0.2); box-shadow: 0 0 20rpx rgba(34,211,238,0.3); }
.journey-node.pending-node { background: rgba(255,255,255,0.06); }
.journey-node-label { color: rgba(255,255,255,0.6); font-size: 22rpx; margin-top: 8rpx; }

/* 羡慕引导区 */
.envy-section { margin: 32rpx 24rpx; }
.envy-card { background: linear-gradient(135deg, rgba(34,211,238,0.1) 0%, rgba(59,102,245,0.1) 100%); border: 1rpx solid rgba(34,211,238,0.25); border-radius: 28rpx; padding: 40rpx 32rpx; text-align: center; }
.envy-icon { font-size: 64rpx; display: block; margin-bottom: 20rpx; }
.envy-title { color: #FFFFFF; font-size: 36rpx; font-weight: 700; display: block; margin-bottom: 16rpx; }
.envy-desc { color: rgba(255,255,255,0.7); font-size: 26rpx; line-height: 1.6; display: block; text-align: left; margin-bottom: 32rpx; }
.envy-steps { display: flex; align-items: center; justify-content: center; margin-bottom: 28rpx; }
.envy-step { display: flex; flex-direction: column; align-items: center; }
.envy-step-num { width: 48rpx; height: 48rpx; background: rgba(34,211,238,0.2); color: #22d3ee; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24rpx; font-weight: 700; }
.envy-step-text { color: rgba(255,255,255,0.7); font-size: 20rpx; margin-top: 8rpx; white-space: nowrap; }
.envy-step-arrow { color: rgba(34,211,238,0.5); font-size: 28rpx; margin: 0 12rpx; padding-bottom: 28rpx; }
.envy-cost-info { background: rgba(34,197,94,0.1); border-radius: 16rpx; padding: 16rpx; }
.envy-cost-free { color: #22C55E; font-size: 30rpx; font-weight: 700; display: block; }
.envy-cost-note { color: rgba(255,255,255,0.5); font-size: 22rpx; display: block; margin-top: 4rpx; }

/* 底部固定按钮 */
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; padding: 16rpx 32rpx; padding-bottom: calc(16rpx + env(safe-area-inset-bottom)); background: linear-gradient(0deg, #0F1B2D 60%, transparent); z-index: 100; }
.apply-btn { display: flex; align-items: center; justify-content: center; gap: 12rpx; background: linear-gradient(135deg, #22d3ee, #3B66F5); border-radius: 52rpx; padding: 28rpx 0; box-shadow: 0 8rpx 32rpx rgba(34,211,238,0.3); }
.apply-btn.disabled { background: rgba(255,255,255,0.15); box-shadow: none; }
.apply-btn-icon { font-size: 36rpx; }
.apply-btn-text { color: #FFFFFF; font-size: 32rpx; font-weight: 700; }

/* 申请弹窗 */
.apply-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.7); z-index: 200; display: flex; align-items: flex-end; }
.apply-modal { background: #1A2740; border-radius: 32rpx 32rpx 0 0; width: 100%; max-height: 85vh; display: flex; flex-direction: column; }
.apply-modal-header { padding: 32rpx; border-bottom: 1rpx solid rgba(255,255,255,0.08); position: relative; }
.apply-modal-title { color: #FFFFFF; font-size: 36rpx; font-weight: 700; display: block; }
.apply-modal-subtitle { color: rgba(255,255,255,0.5); font-size: 24rpx; display: block; margin-top: 8rpx; }
.apply-modal-close { position: absolute; top: 32rpx; right: 32rpx; color: rgba(255,255,255,0.5); font-size: 36rpx; padding: 8rpx; }
.apply-modal-body { padding: 24rpx 32rpx; flex: 1; overflow-y: auto; }
.form-group { margin-bottom: 24rpx; }
.form-group.half { flex: 1; }
.form-row { display: flex; gap: 24rpx; }
.form-label { color: rgba(255,255,255,0.7); font-size: 26rpx; display: block; margin-bottom: 12rpx; }
.form-input { background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.12); border-radius: 16rpx; padding: 20rpx 24rpx; color: #FFFFFF; font-size: 28rpx; }
.form-textarea { background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.12); border-radius: 16rpx; padding: 20rpx 24rpx; color: #FFFFFF; font-size: 28rpx; height: 120rpx; width: 100%; box-sizing: border-box; }
.form-divider { height: 1rpx; background: rgba(255,255,255,0.08); margin: 8rpx 0 24rpx; }
.apply-submit-btn { margin: 16rpx 32rpx 32rpx; background: linear-gradient(135deg, #22d3ee, #3B66F5) !important; color: #FFFFFF !important; border-radius: 52rpx; padding: 24rpx 0; font-size: 30rpx; font-weight: 600; border: none; }
