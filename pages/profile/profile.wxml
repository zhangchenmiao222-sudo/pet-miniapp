<view class="page">
  <view class="nav-bar">
    <text class="nav-title">个人中心</text>
  </view>

  <view class="content" wx:if="{{!loading}}">
    <!-- 用户信息卡片 -->
    <view class="user-card">
      <view class="avatar-wrap">
        <image class="avatar" wx:if="{{userInfo.avatar}}" src="{{userInfo.avatar}}" mode="aspectFill"></image>
        <view class="avatar-placeholder" wx:else>
          <text class="avatar-text">{{userInfo.nickname[0] || 'U'}}</text>
        </view>
      </view>
      <view class="user-info">
        <text class="user-name">{{userInfo.nickname}}</text>
        <view class="member-status" wx:if="{{memberInfo}}">
          <text class="member-badge" wx:if="{{memberInfo.is_active}}">
            {{memberInfo.member_type === 'yearly' ? '年度会员' : memberInfo.member_type === 'quarterly' ? '季度会员' : '月度会员'}}
          </text>
          <text class="member-expire" wx:if="{{memberInfo.is_active}}">到期：{{memberInfo.member_expire_date}}</text>
          <text class="no-member" wx:else>未开通会员</text>
        </view>
      </view>
    </view>

    <!-- 宠物信息 -->
    <view class="section-card" wx:if="{{pet}}">
      <view class="section-header">
        <text class="section-title">我的宠物</text>
      </view>
      <view class="pet-info-row">
        <view class="pet-detail">
          <text class="pet-name">{{pet.name}}</text>
          <text class="pet-basic">{{pet.breed}} · {{pet.age_years}}岁 · {{pet.weight_kg}}kg</text>
          <text class="pet-no">编号 {{pet.pet_no}}</text>
        </view>
      </view>
      <view class="pet-tags" wx:if="{{pet.health_tags.length > 0}}">
        <text class="tag" wx:for="{{pet.health_tags}}" wx:key="index">{{item}}</text>
      </view>
    </view>

    <!-- 会员服务 -->
    <view class="section-card" wx:if="{{!memberInfo || !memberInfo.is_active}}">
      <view class="member-promo">
        <text class="promo-title">开通妙巧巧会员</text>
        <text class="promo-desc">享受专属营养配方、医学分析报告等全部功能</text>
        <view class="promo-btn" bindtap="onBuyMember">128元/年 立即开通</view>
      </view>
    </view>

    <!-- 功能列表 -->
    <view class="section-card menu-card">
      <view class="menu-item" bindtap="onViewPrivacy">
        <text class="menu-text">用户隐私协议</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onContact">
        <text class="menu-text">联系客服</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item logout" bindtap="onLogout">
        <text class="menu-text">退出登录</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="page-bottom">
      <text class="footer-text">妙巧巧·MPFD 精准宠物营养管理 v1.0</text>
    </view>
  </view>

  <view class="loading-wrap" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>
</view>
