.page { background: #0F1923; min-height: 100vh; color: #fff; }
.nav-bar { display: flex; align-items: center; justify-content: center; padding: 100rpx 32rpx 24rpx; }
.nav-title { font-size: 34rpx; font-weight: bold; color: #fff; }
.content { padding: 0 32rpx 80rpx; }

/* 用户信息卡片 */
.user-card { display: flex; align-items: center; background: rgba(59,125,216,0.15); border-radius: 16rpx; padding: 40rpx; margin-bottom: 24rpx; }
.avatar-wrap { margin-right: 28rpx; }
.avatar { width: 120rpx; height: 120rpx; border-radius: 50%; }
.avatar-placeholder { width: 120rpx; height: 120rpx; border-radius: 50%; background: #3B7DD8; display: flex; align-items: center; justify-content: center; }
.avatar-text { font-size: 44rpx; color: #fff; font-weight: bold; }
.user-info { flex: 1; }
.user-name { display: block; font-size: 36rpx; font-weight: bold; color: #fff; margin-bottom: 12rpx; }
.member-badge { display: inline-block; background: #3B7DD8; color: #fff; font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 6rpx; margin-right: 12rpx; }
.member-expire { font-size: 22rpx; color: #8899AA; }
.no-member { font-size: 24rpx; color: #8899AA; }

/* 通用卡片 */
.section-card { background: rgba(255,255,255,0.05); border-radius: 16rpx; padding: 32rpx; margin-bottom: 24rpx; }
.section-header { margin-bottom: 20rpx; }
.section-title { font-size: 28rpx; color: #8899AA; font-weight: bold; }

/* 宠物信息 */
.pet-info-row { display: flex; align-items: center; }
.pet-detail { flex: 1; }
.pet-name { display: block; font-size: 36rpx; font-weight: bold; color: #fff; margin-bottom: 8rpx; }
.pet-basic { display: block; font-size: 26rpx; color: #CDD6E0; margin-bottom: 6rpx; }
.pet-no { display: block; font-size: 22rpx; color: #8899AA; }
.pet-tags { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 20rpx; }
.tag { background: rgba(59,125,216,0.2); color: #3B7DD8; font-size: 22rpx; padding: 6rpx 18rpx; border-radius: 20rpx; }

/* 会员推广 */
.member-promo { text-align: center; }
.promo-title { display: block; font-size: 32rpx; font-weight: bold; color: #fff; margin-bottom: 12rpx; }
.promo-desc { display: block; font-size: 24rpx; color: #8899AA; margin-bottom: 28rpx; }
.promo-btn { display: inline-block; background: #3B7DD8; color: #fff; font-size: 28rpx; padding: 16rpx 60rpx; border-radius: 40rpx; font-weight: bold; }

/* 菜单列表 */
.menu-card { padding: 0; }
.menu-item { display: flex; justify-content: space-between; align-items: center; padding: 32rpx; border-bottom: 1rpx solid rgba(255,255,255,0.06); }
.menu-item:last-child { border-bottom: none; }
.menu-text { font-size: 30rpx; color: #fff; }
.menu-arrow { font-size: 32rpx; color: #8899AA; }
.menu-item.logout .menu-text { color: #EF4444; }

/* 底部 */
.page-bottom { text-align: center; padding: 40rpx 0; }
.footer-text { font-size: 22rpx; color: #8899AA; }

.loading-wrap { padding: 200rpx 0; text-align: center; }
.loading-text { color: #8899AA; font-size: 28rpx; }
