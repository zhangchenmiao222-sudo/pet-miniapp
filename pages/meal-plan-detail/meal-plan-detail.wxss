.page { background: #0F1923; min-height: 100vh; color: #fff; }
.nav-bar { display: flex; align-items: center; justify-content: space-between; padding: 100rpx 32rpx 24rpx; }
.nav-back { width: 60rpx; display: flex; align-items: center; }
.nav-back-icon { font-size: 48rpx; color: #fff; }
.nav-title { font-size: 32rpx; font-weight: bold; color: #fff; }
.nav-placeholder { width: 60rpx; }
.content { padding: 0 32rpx 80rpx; }
.status-card { background: rgba(59,125,216,0.15); border-radius: 16rpx; padding: 40rpx; margin-bottom: 24rpx; }
.status-live-row { display: flex; align-items: center; margin-bottom: 16rpx; }
.live-dot { width: 16rpx; height: 16rpx; border-radius: 50%; background: #8899AA; margin-right: 12rpx; }
.live-dot.active { background: #4CAF50; box-shadow: 0 0 8rpx #4CAF50; }
.live-label { font-size: 24rpx; color: #4CAF50; font-weight: bold; }
.stage-title { display: block; font-size: 40rpx; font-weight: bold; color: #fff; margin-bottom: 12rpx; }
.formula-name { font-size: 26rpx; color: #8899AA; }
.section-card { background: rgba(255,255,255,0.05); border-radius: 16rpx; padding: 32rpx; margin-bottom: 24rpx; }
.section-title { display: block; font-size: 28rpx; color: #8899AA; margin-bottom: 24rpx; }
.stages-row { display: flex; align-items: center; justify-content: space-between; }
.stage-item { display: flex; flex-direction: column; align-items: center; opacity: 0.4; }
.stage-item.active { opacity: 1; }
.stage-icon { font-size: 36rpx; margin-bottom: 8rpx; }
.stage-label { font-size: 20rpx; color: #fff; text-align: center; }
.stage-arrow { font-size: 28rpx; color: #3B7DD8; }
.progress-row { display: flex; align-items: center; gap: 20rpx; margin-bottom: 16rpx; }
.progress-bg { flex: 1; height: 16rpx; background: rgba(255,255,255,0.1); border-radius: 8rpx; overflow: hidden; }
.progress-fill { height: 100%; background: #3B7DD8; border-radius: 8rpx; }
.progress-num { font-size: 28rpx; color: #3B7DD8; font-weight: bold; min-width: 80rpx; }
.planned-days { font-size: 26rpx; color: #8899AA; }
.loading-wrap { padding: 100rpx; text-align: center; }
.loading-text { color: #8899AA; font-size: 28rpx; }
