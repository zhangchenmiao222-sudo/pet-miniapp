.page { background: #0F1923; min-height: 100vh; color: #fff; }
.nav-bar { display: flex; align-items: center; justify-content: space-between; padding: 100rpx 32rpx 24rpx; }
.nav-back { width: 60rpx; display: flex; align-items: center; }
.nav-back-icon { font-size: 48rpx; color: #fff; }
.nav-title { font-size: 32rpx; font-weight: bold; color: #fff; }
.nav-placeholder { width: 60rpx; }
.content { padding: 0 40rpx 80rpx; }
.main-title { display: block; font-size: 36rpx; font-weight: bold; color: #fff; margin-bottom: 12rpx; }
.update-date { display: block; font-size: 24rpx; color: #8899AA; margin-bottom: 48rpx; }
.section { margin-bottom: 40rpx; }
.section-title { display: block; font-size: 30rpx; font-weight: bold; color: #fff; margin-bottom: 20rpx; }
.paragraph { display: block; font-size: 28rpx; color: #CDD6E0; line-height: 1.8; margin-bottom: 16rpx; }
.list-item { display: block; font-size: 28rpx; color: #CDD6E0; line-height: 1.8; margin-bottom: 12rpx; padding-left: 16rpx; }
.contact { display: block; font-size: 28rpx; color: #3B7DD8; margin-top: 12rpx; }
.footer { margin-top: 60rpx; padding-top: 40rpx; border-top: 1rpx solid rgba(255,255,255,0.1); text-align: center; }
.footer-text { font-size: 24rpx; color: #8899AA; }
